-- backfire
local function playBackfire()
	if not canPop then return end
	canPop = false

	for i = 1, 3 do
		local p = Instance.new("Sound", rootPart)
		p.SoundId = "rbxassetid://140562715692021"
		p.Volume = 2.5
		p.PlayOnRemove = true
		p:Destroy()

		task.wait(math.random(10, 30) / 100)
	end

	canPop = true
end

local function createBtn(name, pos, size, text, color, key)
	local btn = Instance.new("TextButton", screenGui)
	btn.Name = name
	btn.Size = size
	btn.Position = pos
	btn.BackgroundColor3 = Color3.fromRGB(20,20,20)
	btn.BackgroundTransparency = 0.4
	btn.Text = text
	btn.TextColor3 = Color3.new(1,1,1)
	btn.TextScaled = true

	Instance.new("UICorner", btn)

	local stroke = Instance.new("UIStroke", btn)
	stroke.Thickness = 2
	stroke.Color = color

	btn.MouseButton1Down:Connect(function()
		keysPressed[key] = true
	end)

	btn.MouseButton1Up:Connect(function()
		if key == "W" and currentSpeed > 50 then
			task.spawn(playBackfire)
		end
		keysPressed[key] = false
	end)

	btn.MouseLeave:Connect(function()
		keysPressed[key] = false
	end)

	return btn
end


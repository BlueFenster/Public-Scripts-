	else
		if carBase then carBase:Destroy() end
		if idleSound then idleSound:Destroy() end
		if moveSound then moveSound:Destroy() end
		if brakeSound then brakeSound:Destroy() end
		if attL then attL:Destroy() end
		if attR then attR:Destroy() end

		humanoid.Sit = false

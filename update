-- // drive toggle logic
toggleButton.Activated:Connect(function()
	isDriving = not isDriving
	if isDriving then
		createCarBase()
		humanoid.WalkSpeed = 0
		humanoid.Sit = true
		screenGui.Enabled = true

		toggleButton.Text = "STOP DRIVING"
		toggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
	else
		if carBase then carBase:Destroy() end
		if idleSound then idleSound:Destroy() end
		if moveSound then moveSound:Destroy() end
		if brakeSound then brakeSound:Destroy() end
		if attL then attL:Destroy() end
		if attR then attR:Destroy() end

		humanoid.Sit = false
		humanoid.WalkSpeed = 16
		currentSpeed = 0
		screenGui.Enabled = false
	end
end)

-- // main driving loop
runService.Heartbeat:Connect(function(deltaTime)
	if not isDriving or not carBase then return end

	local absSpeed = math.abs(currentSpeed)
	local isNight = lighting.ClockTime >= 18 or lighting.ClockTime <= 6
	if lightL and lightR then
		lightL.Enabled = isNight
		lightR.Enabled = isNight
	end

	if keysPressed.W then
		currentSpeed = math.min(currentSpeed + currentAccel, currentMaxSpeed)
	elseif keysPressed.S then
		currentSpeed = math.max(currentSpeed - currentDecel, -currentMaxSpeed * 0.4)
	else
		currentSpeed = currentSpeed * (1 - inertiaFriction)
	end

	if keysPressed.A then targetRotation = targetRotation + turningSpeed * deltaTime end
	if keysPressed.D then targetRotation = targetRotation - turningSpeed * deltaTime end

	bodyGyro.CFrame = CFrame.Angles(0, targetRotation, 0)
	bodyVelocity.Velocity = bodyGyro.CFrame.LookVector * currentSpeed
	speedText.Text = tostring(math.floor(absSpeed))
end)

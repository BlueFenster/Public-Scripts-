runService.Heartbeat:Connect(function(deltaTime)
	if not isDriving or not carBase then return end

	local absSpeed = math.abs(currentSpeed)

	local isNight = lighting.ClockTime >= 18 or lighting.ClockTime <= 6

	if lightL and lightR then
		lightL.Enabled = isNight
		lightR.Enabled = isNight
	end

	-- movement
	if keysPressed.W then
		local accelCurve = 0.3 + (absSpeed / maxSpeed) * 0.7
		currentSpeed = math.min(currentSpeed + accelCurve, maxSpeed)

		if brakeSound.IsPlaying then
			brakeSound:Stop()
		end

	elseif keysPressed.S then
		if currentSpeed > 0 then
			currentSpeed = math.max(currentSpeed - 1.6, 0)

			if currentSpeed > 15 and not brakeSound.IsPlaying then
				brakeSound.Volume = 0.8
				brakeSound:Play()
			end
		else
			currentSpeed = math.max(currentSpeed - 0.05, -reverseMaxSpeed)
			brakeSound:Stop()
		end
	else
		currentSpeed = currentSpeed * (1 - inertiaFriction)

		if brakeSound.IsPlaying then
			brakeSound:Stop()
		end
	end

	-- audio
	if currentSpeed < 0 then
		idleSound.Volume = 1
		moveSound.Volume = 0
	else
		idleSound.Volume = absSpeed < 1 and 1 or 0

		if absSpeed >= 1 then
			moveSound.Volume = keysPressed.W and 1 or 0.5
			moveSound.PlaybackSpeed = 0.9 + (absSpeed / maxSpeed) * 1.6
		else
			moveSound.Volume = 0
		end
	end

	-- lean
	local leanLimitFactor = math.clamp(absSpeed / 200, 0.15, 1)
	local dynamicMaxLean = maxLeanAngleBase * leanLimitFactor

	local targetLean = 0

	if keysPressed.A then
		targetLean = math.rad(dynamicMaxLean)
	elseif keysPressed.D then
		targetLean = -math.rad(dynamicMaxLean)
	end

	currentLean = math.lerp(currentLean, targetLean, deltaTime * 3)

	local leanBonus = (math.abs(currentLean) > math.rad(20) and absSpeed > 150) and 1.3 or 1.0

	local dynamicTurning =
		(absSpeed > 0.1)
		and (turningSpeed / (1 + (absSpeed / 120))) * leanBonus
		or 0

	if keysPressed.A then
		targetRotation = targetRotation + dynamicTurning * deltaTime
	end

	if keysPressed.D then
		targetRotation = targetRotation - dynamicTurning * deltaTime
	end

	-- physics
	local raycastParams = RaycastParams.new()
	raycastParams.FilterDescendantsInstances = {character, carBase}
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude

	local rayResult = workspace:Raycast(
		rootPart.Position,
		Vector3.new(0,-10,0),
		raycastParams
	)

	if rayResult then
		local compression = targetDistance - (rootPart.Position - rayResult.Position).Magnitude
		local velocity = (compression - lastVerticalError) / deltaTime

		lastVerticalError = compression

		bodyForce.Force = Vector3.new(
			0,
			math.max(0, (compression * stiffness) + (velocity * damping)),
			0
		)
	else
		bodyForce.Force = Vector3.new(0,0,0)
		lastVerticalError = 0
	end

	bodyGyro.CFrame =
		CFrame.Angles(0, targetRotation, 0) *
		CFrame.Angles(0,0,currentLean)

	bodyVelocity.Velocity =
		bodyVelocity.Velocity:Lerp(
			bodyGyro.CFrame.LookVector * currentSpeed,
			0.15
		)

	speedText.Text = tostring(math.floor(absSpeed))
end)
